# =============================================================================
# SIGMA INTELLIGENCE PLATFORM — Environment Variables
# Copy this file to .env and fill in your team values
# Bedrock IDs come from Anil at the start of class
# =============================================================================

# AWS
AWS_DEFAULT_REGION=us-east-1
SIGMA_S3_BUCKET=sigma-datatech-YOURTEAM
SIGMA_STREAM=sigma-transactions

# Bedrock — Anil provides these at 11 AM
SUPERVISOR_AGENT_ID=
SUPERVISOR_ALIAS_ID=TSTALIASID
KNOWLEDGE_BASE_ID=
GUARDRAIL_ID=
GUARDRAIL_VERSION=DRAFT

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=SIGMA
SNOWFLAKE_WAREHOUSE=SIGMA_WH
SNOWFLAKE_SCHEMA=SILVER

# AWS resources — from your account
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNTID:sigma-alerts
LAMBDA_ROLE_ARN=arn:aws:iam::ACCOUNTID:role/sigma-lambda-role

# Lambda function under investigation (pre-deployed by trainer)
PRODUCER_LAMBDA_NAME=sigma-kinesis-producer
PRODUCER_LAMBDA_ALIAS=LIVE

# Optional: Langfuse observability — sign up free at https://langfuse.com
# Leave blank to skip (lab works without it)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
